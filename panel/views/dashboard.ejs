
<!DOCTYPE html>
<html>
<body style="background:#020617;color:#fff;font-family:Arial">

<h2>Enterprise Panel</h2>

<form method="POST" action="/add" enctype="multipart/form-data">
<textarea name="caption" style="width:100%;height:120px"></textarea>
<input type="file" name="photo">
<input name="interval" placeholder="Interval menit">
<input name="btn_text" placeholder="Text tombol (,)">
<input name="btn_url" placeholder="URL tombol (,)">
<button>Tambah</button>
</form>

<hr>

<% data.campaigns.forEach(c=>{ %>
<div>
<b><%= c.caption %></b><br>
<small><%= c.active ? 'ON':'OFF' %></small><br>
<a href="/toggle/<%=c.id%>">Toggle</a>
<a href="/delete/<%=c.id%>">Hapus</a>
</div>
<% }) %>

</body>
</html>
