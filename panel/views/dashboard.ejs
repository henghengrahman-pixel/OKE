<!DOCTYPE html>

<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Broadcast</title>

<style>
body{
  font-family:Arial;
  background:#020617;
  color:#fff;
  margin:0;
  padding:20px;
}
h2{margin-bottom:10px;}

.card{
  background:#0f172a;
  padding:15px;
  border-radius:10px;
  margin-bottom:20px;
}

input, textarea{
  width:100%;
  padding:10px;
  margin-top:8px;
  border-radius:8px;
  border:1px solid #1e293b;
  background:#020617;
  color:#fff;
}

textarea{
  min-height:100px;
  resize:vertical;
}

button{
  margin-top:10px;
  padding:10px 14px;
  border:0;
  border-radius:8px;
  background:#3b82f6;
  color:#fff;
  cursor:pointer;
}

.item{
  background:#020617;
  padding:12px;
  border-radius:8px;
  margin-top:10px;
}

a{
  color:#ef4444;
  text-decoration:none;
  font-size:12px;
}

img{
  width:100%;
  border-radius:8px;
  margin-top:10px;
}
</style>

</head>

<body>

<h2>🚀 Dashboard Broadcast</h2>

<div class="card">
  <a href="/toggle"><button>ON / OFF SYSTEM</button></a>
</div>

<div class="card">
  <h3>Tambah Campaign</h3>

  <!-- WAJIB enctype untuk upload -->

  <form method="POST" action="/add" enctype="multipart/form-data">

```
<textarea name="caption" placeholder="Caption (bisa enter)" required></textarea>

<input type="file" name="photo">

<input type="number" name="interval" placeholder="Interval menit (contoh: 30)" required>

<input name="btn_text" placeholder="Text tombol (pisah koma)">
<input name="btn_url" placeholder="URL tombol (pisah koma)">

<button>Tambah</button>
```

  </form>
</div>

<div class="card">
  <h3>List Campaign</h3>

<% if(data.campaigns.length === 0){ %> <p style="opacity:.6">Belum ada data</p>
<% } %>

<% data.campaigns.forEach(c=>{ %> <div class="item">

```
  <b style="white-space:pre-line;"><%= c.caption %></b><br>
  <small>ID: <%= c.id %></small><br>
  <small>Interval: <%= Math.floor(c.interval/60) %> menit</small><br>
  <small>Status: <%= c.active ? 'ON':'OFF' %></small>

  <% if(c.photo){ %>
    <img src="<%= c.photo %>">
  <% } %>

  <% if(c.buttons && c.buttons.length){ %>
    <div style="margin-top:8px;">
      <% c.buttons.forEach(b=>{ %>
        <div style="font-size:12px;">🔗 <%= b.text %></div>
      <% }) %>
    </div>
  <% } %>

  <div style="margin-top:10px;">
    <a href="/toggle/<%=c.id%>">Toggle</a> |
    <a href="/delete/<%=c.id%>">Hapus</a>
  </div>

</div>
```

<% }) %>

</div>

</body>
</html>
